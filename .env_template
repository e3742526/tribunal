# Copy to `.env` for local development.
# `tagteam` reads `.env` from the selected workdir as a scoped overlay.
# It does not mutate the global process environment, and exported shell
# variables still take precedence.

# OpenAI-compatible adapters
# Use these with [adapters.openai_compatible] in `.tagteam.toml`.
FEATHERLESS_API_KEY=""
OPENROUTER_API_KEY=""
PURDUE_API_KEY=""

# Anthropic
# Claude CLI usually uses `claude login`; uncomment only if your local setup
# reads API keys from the environment.
# ANTHROPIC_API_KEY=""

# OpenAI
# Codex CLI usually uses `codex login`; uncomment only if your local setup
# reads API keys from the environment.
# OPENAI_API_KEY=""

# Gemini / Google
# `agy` may use login or environment-based auth depending on local setup.
# GEMINI_API_KEY=""
# GOOGLE_API_KEY=""

# Ollama
# Uncomment if your local Ollama instance is not on the default host.
# OLLAMA_HOST="http://127.0.0.1:11434"
